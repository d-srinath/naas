oc project bamoe-dev

oc patch deployment bamoe-management-console -p '{"spec":{"template":{"spec":{"enableServiceLinks":false}}}}'

oc set env deployment/bamoe-management-console PORT-

oc set env deployment/bamoe-management-console HTTPD_PORT-

oc rollout restart deployment/bamoe-management-console

oc rollout status deployment/bamoe-management-console

oc get pods
