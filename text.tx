# -------------------------------------------------
# 1. Delete old namespaces
# -------------------------------------------------
oc delete project bamoe-canvas
oc delete project bamoe-dev

# -------------------------------------------------
# 2. Recreate namespaces
# -------------------------------------------------
oc new-project bamoe-canvas
oc new-project bamoe-dev

# -------------------------------------------------
# 3. Switch to Canvas namespace
# -------------------------------------------------
oc project bamoe-canvas

# -------------------------------------------------
# 4. Deploy BAMOE Extended Services
# -------------------------------------------------
oc create deployment bamoe-extended-services --image=quay.io/bamoe/extended-services-java:9.3.1-ibm-0006
oc set env deployment/bamoe-extended-services QUARKUS_HTTP_PORT=8080
oc expose deployment bamoe-extended-services --port=8080
oc create route edge --service=bamoe-extended-services

# -------------------------------------------------
# 5. Deploy BAMOE CORS Proxy
# -------------------------------------------------
oc create deployment bamoe-cors-proxy --image=quay.io/bamoe/cors-proxy:9.3.1-ibm-0006
oc set env deployment/bamoe-cors-proxy QUARKUS_HTTP_PORT=8080
oc expose deployment bamoe-cors-proxy --port=8080
oc create route edge --service=bamoe-cors-proxy

# -------------------------------------------------
# 6. Capture backend routes
# -------------------------------------------------
export EXT_URL=https://$(oc get route bamoe-extended-services -o jsonpath='{.spec.host}')
export CORS_URL=https://$(oc get route bamoe-cors-proxy -o jsonpath='{.spec.host}')

# -------------------------------------------------
# 7. Deploy BAMOE Canvas UI
# -------------------------------------------------
oc create deployment bamoe-canvas --image=quay.io/bamoe/canvas:9.3.1-ibm-0006
oc set env deployment/bamoe-canvas KIE_SANDBOX_EXTENDED_SERVICES_URL=$EXT_URL
oc set env deployment/bamoe-canvas KIE_SANDBOX_CORS_PROXY_URL=$CORS_URL
oc expose deployment bamoe-canvas --port=8080
oc create route edge --service=bamoe-canvas

# -------------------------------------------------
# 8. Deploy BAMOE Management Console
# -------------------------------------------------
oc create deployment bamoe-management-console --image=quay.io/bamoe/management-console:9.3.1-ibm-0006
oc set env deployment/bamoe-management-console QUARKUS_HTTP_PORT=8080
oc expose deployment bamoe-management-console --port=8080
oc create route edge --service=bamoe-management-console

# -------------------------------------------------
# 9. Deploy BAMOE Maven Repository
# -------------------------------------------------
oc create deployment bamoe-maven-repo --image=quay.io/bamoe/maven-repository:9.3.1-ibm-0006
oc expose deployment bamoe-maven-repo --port=8080
oc create route edge --service=bamoe-maven-repo

# -------------------------------------------------
# 10. Verify deployments, services, and routes
# -------------------------------------------------
oc get deployments
oc get pods
oc get svc
oc get routes
